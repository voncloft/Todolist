[Desktop Entry]
Type=Service
Name=Create Todo List
MimeType=inode/directory;
Actions=createTodoList;
Icon=view-pim-tasks
X-KDE-ServiceTypes=KonqPopupMenu/Plugin
X-KDE-MinNumberOfUrls=0
X-KDE-MaxNumberOfUrls=1
X-KDE-Priority=TopLevel
X-KDE-Protocols=file

[Desktop Action createTodoList]
Name=Create Todo List
Icon=view-pim-tasks
Exec=@LAUNCHER@ %u
